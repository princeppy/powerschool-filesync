{
  "name": "powerschoolfilesync",
  "displayName": "PowerSchoolFileSync",
  "description": "PowerSchool File Sync, forked from https://github.com/pgmjah/filesync-vsce",
  "publisher": "prince",
  "icon": "images/icon.png",
  "author": {
    "name": "Prince PARK",
    "email": "prince_ppy@yahoo.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/princeppy/powerschool-filesync.git"
  },
  "keywords": [
    "PowerSchool - File Synchronization",
    "PowerSchool - File Management",
    "PowerSchool - File Copying",
    "PowerSchool - File Deployment"
  ],
  "license": "MIT",
  "version": "3.0.7",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:fsconfig.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "psfilesync.createConfigFile",
        "title": "PS FileSync: Create a fsconfig.json file."
      },
      {
        "command": "psfilesync.startAllSyncs",
        "title": "PS FileSync: Start all synchronizing files/directories."
      },
      {
        "command": "psfilesync.stopAllSyncs",
        "title": "PS FileSync: Stop all synchronizing files/directories."
      },
      {
        "command": "psfilesync.syncCurrentFile",
        "title": "PS FileSync: Sync Current File",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "psfilesync.syncAllFiles",
        "title": "PS FileSync: Sync All Files"
      },
      {
        "command": "psfilesync.refreshTree",
        "title": "PS FileSync: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "psfilesync.syncTreeFile",
        "title": "PS FileSync: Sync File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "psfilesync.syncCurrentFile",
          "when": "psfilesync.hasConfig",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "psfilesync.refreshTree",
          "when": "view == psfilesync.syncTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "psfilesync.startAllSyncs",
          "when": "view == psfilesync.syncTree && viewItem == configEntry",
          "group": "inline"
        },
        {
          "command": "psfilesync.stopAllSyncs",
          "when": "view == psfilesync.syncTree && viewItem == configEntry",
          "group": "inline"
        },
        {
          "command": "psfilesync.syncAllFiles",
          "when": "view == psfilesync.syncTree && viewItem == configEntry"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "psfilesync-sidebar",
          "title": "PowerSchool File Sync",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "psfilesync-sidebar": [
        {
          "id": "psfilesync.syncTree",
          "name": "Sync Configurations",
          "contextualTitle": "PowerSchool File Sync"
        }
      ]
    },
    "configuration": []
  },
  "scripts": {
    "vscode:prepublish": "rm -f *.vsix && yarn version --patch --no-git-tag-version && yarn run package",
    "compile": "yarn run check-types && yarn run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
